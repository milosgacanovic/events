{
  "name": "dr-events-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @dr-events/shared && npm run build -w @dr-events/api && npm run build -w @dr-events/web",
    "dev:api": "npm run build -w @dr-events/shared && npm run dev -w @dr-events/api",
    "dev:web": "npm run build -w @dr-events/shared && npm run dev -w @dr-events/web",
    "typecheck": "npm run build -w @dr-events/shared && npm run typecheck -w @dr-events/api && npm run typecheck -w @dr-events/web && npm run typecheck -w @dr-events/shared",
    "test": "npm run test -w @dr-events/api",
    "import:smoke": "tsx scripts/import-smoke.ts",
    "postdeploy:smoke": "tsx scripts/post-deploy-smoke.ts",
    "test:live:admin": "tsx scripts/live-admin-verify.ts",
    "release:gate": "ts-node scripts/releaseGate.ts",
    "meili:backup": "ts-node scripts/meiliBackup.ts",
    "occurrences:dedupe:single": "tsx scripts/cleanup-single-occurrence-duplicates.ts",
    "occurrences:reindex:all": "tsx scripts/reindexAllOccurrences.ts",
    "bg:init:apache": "bash scripts/bg-init-apache.sh",
    "bg:active": "bash scripts/bg-active-color.sh",
    "bg:switch": "bash scripts/bg-switch.sh",
    "bg:deploy": "bash scripts/bg-deploy.sh",
    "bg:rollback": "bash scripts/bg-rollback.sh",
    "bg:cleanup": "bash scripts/bg-cleanup.sh",
    "migrate": "npm run migrate -w @dr-events/api",
    "seed": "npm run seed -w @dr-events/api",
    "occurrences:refresh": "npm run occurrences:refresh -w @dr-events/api"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
