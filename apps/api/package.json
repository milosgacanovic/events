    "@types/node": "^22.13.10",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.11",
    "@types/supercluster": "^7.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
