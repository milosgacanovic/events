{
  "name": "@dr-events/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/scripts/migrate.ts",
    "seed": "tsx src/scripts/seed.ts",
    "occurrences:refresh": "tsx src/scripts/refreshOccurrences.ts",
    "alerts:notify": "tsx src/scripts/runAlertNotifications.ts"
  },
  "dependencies": {
    "@dr-events/shared": "0.1.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^8.1.1",
    "@types/sanitize-html": "^2.16.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jose": "^5.9.6",
    "lru-cache": "^11.0.2",
    "luxon": "^3.5.0",
    "meilisearch": "^0.49.0",
    "nodemailer": "^8.0.3",
    "pg": "^8.13.3",
    "rrule": "^2.8.1",
    "sanitize-html": "^2.17.3",
    "slugify": "^1.6.6",
    "supercluster": "^8.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
